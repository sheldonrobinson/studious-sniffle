{
  "openapi": "3.0.3",
  "info": {
    "title": "REST Countries API",
    "version": "3.1.0",
    "description": "OpenAPI 3.0 specification for REST Countries v3.1.\n\nBase URL: https://restcountries.com\n\nYou must specify the `fields` query parameter (up to 10 fields) when calling the `/v3.1/all` endpoint, otherwise you'll get a bad request response."
  },
  "servers": [
    {
      "url": "https://restcountries.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/v3.1/all": {
      "get": {
        "operationId": "getAllCountries",
        "summary": "Get all countries",
        "description": "Retrieve information about all countries. You must specify the `fields` query parameter (up to 10 fields).",
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of fields to include in the response (up to 10).",
            "schema": {
              "type": "string",
              "example": "name,capital,currencies"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of countries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Country"
                  }
                },
                "examples": {
                  "allCountriesWithNameFlags": {
                    "summary": "All countries with name and flags",
                    "value": [
                      {
                        "name": {
                          "common": "Peru",
                          "official": "Republic of Peru",
                          "nativeName": {
                            "spa": {
                              "official": "República del Perú",
                              "common": "Perú"
                            }
                          }
                        },
                        "flags": {
                          "png": "https://flagcdn.com/w320/pe.png",
                          "svg": "https://flagcdn.com/pe.svg",
                          "alt": "The flag of Peru"
                        }
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request (e.g., missing or invalid fields parameter)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "status": 400,
                  "message": "You must specify up to 10 fields when calling /v3.1/all"
                }
              }
            }
          }
        }
      }
    },
    "/v3.1/name/{name}": {
      "get": {
        "operationId": "getCountriesByName",
        "summary": "Get countries by name",
        "description": "Search by country name (common or official value).",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Country name (common or official).",
            "schema": {
              "type": "string",
              "example": "peru"
            }
          },
          {
            "name": "fullText",
            "in": "query",
            "required": false,
            "description": "If true, search by full country name (common or official).",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "example": true
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of fields to include in the response.",
            "schema": {
              "type": "string",
              "example": "name,capital,currencies"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching countries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Country"
                  }
                },
                "examples": {
                  "byName": {
                    "summary": "Search by name",
                    "value": [
                      {
                        "name": {
                          "common": "Peru",
                          "official": "Republic of Peru"
                        },
                        "capital": ["Lima"],
                        "region": "Americas",
                        "cca2": "PE",
                        "cca3": "PER"
                      }
                    ]
                  },
                  "byFullName": {
                    "summary": "Search by full name",
                    "value": [
                      {
                        "name": {
                          "common": "Aruba",
                          "official": "Aruba"
                        },
                        "capital": ["Oranjestad"],
                        "region": "Americas",
                        "cca2": "AW",
                        "cca3": "ABW"
                      }
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "No countries found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "status": 404,
                  "message": "Not Found"
                }
              }
            }
          }
        }
      }
    },
    "/v3.1/alpha/{code}": {
      "get": {
        "operationId": "getCountryByCode",
        "summary": "Get country by code",
        "description": "Search by `cca2`, `ccn3`, `cca3` or `cioc` country code.",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "description": "Country code (cca2, ccn3, cca3 or cioc).",
            "schema": {
              "type": "string",
              "example": "co"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of fields to include in the response.",
            "schema": {
              "type": "string",
              "example": "name,capital,currencies"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Country found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Country"
                  }
                },
                "example": [
                  {
                    "name": {
                      "common": "Colombia",
                      "official": "Republic of Colombia"
                    },
                    "cca2": "CO",
                    "cca3": "COL",
                    "ccn3": "170",
                    "cioc": "COL",
                    "capital": ["Bogotá"],
                    "region": "Americas"
                  }
                ]
              }
            }
          },
          "404": {
            "description": "Country not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "status": 404,
                  "message": "Not Found"
                }
              }
            }
          }
        }
      }
    },
    "/v3.1/alpha": {
      "get": {
        "operationId": "getCountriesByCodes",
        "summary": "Get countries by list of codes",
        "description": "Search by multiple country codes at once.",
        "parameters": [
          {
            "name": "codes",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of country codes (cca2, ccn3, cca3 or cioc).",
            "schema": {
              "type": "string",
              "example": "170,no,est,pe"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of fields to include in the response.",
            "schema": {
              "type": "string",
              "example": "name,capital,currencies"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Countries found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Country"
                  }
                },
                "example": [
                  {
                    "name": {
                      "common": "Colombia",
                      "official": "Republic of Colombia"
                    },
                    "cca3": "COL"
                  },
                  {
                    "name": {
                      "common": "Norway",
                      "official": "Kingdom of Norway"
                    },
                    "cca3": "NOR"
                  }
                ]
              }
            }
          },
          "404": {
            "description": "No countries found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v3.1/currency/{currency}": {
      "get": {
        "operationId": "getCountriesByCurrency",
        "summary": "Get countries by currency",
        "description": "Search by currency code or name.",
        "parameters": [
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "description": "Currency code or name.",
            "schema": {
              "type": "string",
              "example": "cop"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of fields to include in the response.",
            "schema": {
              "type": "string",
              "example": "name,currencies"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Countries using the currency",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Country"
                  }
                },
                "example": [
                  {
                    "name": {
                      "common": "Colombia",
                      "official": "Republic of Colombia"
                    },
                    "currencies": {
                      "COP": {
                        "name": "Colombian peso",
                        "symbol": "$"
                      }
                    }
                  }
                ]
              }
            }
          },
          "404": {
            "description": "No countries found for currency",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
