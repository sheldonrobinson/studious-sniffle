    "/v3.1/independent": {
      "get": {
        "operationId": "getCountriesByIndependenceStatus",
        "summary": "Get countries by independence status",
        "description": "Get all independent (or non-independent) countries.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": true,
            "description": "Independence status (true for independent, false for non-independent).",
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of fields to include in the response.",
            "schema": {
              "type": "string",
              "example": "languages,capital"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Countries filtered by independence status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Country"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid status parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v3.1/{service}": {
      "get": {
        "operationId": "getCountriesByServiceWithFields",
        "summary": "Filter response fields for any service",
        "description": "Filter the output of any service to include only specified fields.",
        "parameters": [
          {
            "name": "service",
            "in": "path",
            "required": true,
            "description": "Service name (e.g., all, name/peru, alpha/co, region/europe).",
            "schema": {
              "type": "string",
              "example": "all"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of fields to include in the response.",
            "schema": {
              "type": "string",
              "example": "name,capital,currencies"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filtered response from the service",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Country"
                  }
                },
                "example": [
                  {
                    "name": {
                      "common": "Peru",
                      "official": "Republic of Peru"
                    },
                    "capital": ["Lima"],
                    "currencies": {
                      "PEN": {
                        "name": "Peruvian sol",
                        "symbol": "S/."
                      }
                    }
                  }
                ]
              }
            }
          },
          "400": {
            "description": "Invalid service or fields parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Country": {
        "type": "object",
        "description": "Country representation for REST Countries v3.1.",
        "properties": {
          "name": {
            "$ref": "#/components/schemas/Name"
          },
          "cca2": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 two-letter country code.",
            "example": "PE"
          },
          "cca3": {
            "type": "string",
            "description": "ISO 3166-1 alpha-3 three-letter country code.",
            "example": "PER"
          },
          "ccn3": {
            "type": "string",
            "description": "ISO 3166-1 numeric code (UN M49).",
            "example": "604"
          },
          "cioc": {
            "type": "string",
            "description": "Code of the International Olympic Committee.",
            "example": "PER"
          },
          "independent": {
            "type": "boolean",
            "description": "ISO 3166-1 independence status (the country is considered a sovereign state).",
            "example": true
          },
          "status": {
            "type": "string",
            "description": "ISO 3166-1 assignment status.",
            "example": "officially-assigned"
          },
          "unMember": {
            "type": "boolean",
            "description": "UN Member status.",
            "example": true
          },
          "capital": {
            "type": "array",
            "description": "Capital cities.",
            "items": {
              "type": "string"
            },
            "example": ["Lima"]
          },
          "capitalInfo": {
            "type": "object",
            "description": "Capital latitude and longitude.",
            "properties": {
              "latlng": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "example": [-12.0464, -77.0428]
              }
            }
          },
          "region": {
            "type": "string",
            "description": "UN demographic region.",
            "example": "Americas"
          },
          "subregion": {
            "type": "string",
            "description": "UN demographic subregion.",
            "example": "South America"
          },
          "languages": {
            "type": "object",
            "description": "List of official languages (keyed by ISO language code).",
            "additionalProperties": {
              "type": "string"
            },
            "example": {
              "spa": "Spanish"
            }
          },
          "translations": {
            "type": "object",
            "description": "List of country name translations.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Translation"
            }
          },
          "latlng": {
            "type": "array",
            "description": "Latitude and longitude.",
            "items": {
              "type": "number"
            },
            "example": [-10.0, -76.0]
          },
          "borders": {
            "type": "array",
            "description": "Border countries (cca3 codes).",
            "items": {
              "type": "string"
            },
            "example": ["BOL", "BRA", "CHL", "COL", "ECU"]
          },
          "area": {
            "type": "number",
            "description": "Geographical size in square kilometers.",
            "example": 1285216
          },
          "flag": {
            "type": "string",
            "description": "Flag emoji.",
            "example": "🇵🇪"
          },
          "flags": {
            "$ref": "#/components/schemas/Flags"
          },
          "coatOfArms": {
            "$ref": "#/components/schemas/CoatOfArms"
          },
          "maps": {
            "$ref": "#/components/schemas/Maps"
          },
          "population": {
            "type": "integer",
            "description": "Country population.",
            "example": 32971846
          },
          "timezones": {
            "type": "array",
            "description": "Timezones.",
            "items": {
              "type": "string"
            },
            "example": ["UTC-05:00"]
          },
          "continents": {
            "type": "array",
            "description": "List of continents the country is on.",
            "items": {
              "type": "string"
            },
            "example": ["South America"]
          },
          "startOfWeek": {
            "type": "string",
            "description": "Day of the start of week (Sunday/Monday/Saturday).",
            "example": "monday"
          },
          "tld": {
            "type": "array",
            "description": "Internet top level domains.",
            "items": {
              "type": "string"
            },
            "example": [".pe"]
          },
          "idd": {
            "$ref": "#/components/schemas/Idd"
          },
          "currencies": {
            "type": "object",
            "description": "List of all currencies.",
            "additionalProperties": {
              "$ref": "#/components/schemas/Currency"
            },
            "example": {
              "PEN": {
                "name": "Peruvian sol",
                "symbol": "S/."
              }
            }
          },
          "car": {
            "$ref": "#/components/schemas/Car"
          },
          "gini": {
            "type": "object",
            "description": "World Bank Gini index by year.",
            "additionalProperties": {
              "type": "number"
            },
            "example": {
              "2019": 41.5
            }
          },
          "landlocked": {
            "type": "boolean",
            "description": "Landlocked country.",
            "example": false
          },
          "demonyms": {
            "$ref": "#/components/schemas/Demonyms"
          },
          "fifa": {
            "type": "string",
            "description": "FIFA code.",
            "example": "PER"
          }
        }
      },
      "Name": {
        "type": "object",
        "description": "Country name information.",
        "properties": {
          "common": {
            "type": "string",
            "description": "Common country name.",
            "example": "Peru"
          },
          "official": {
            "type": "string",
            "description": "Official country name.",
            "example": "Republic of Peru"
          },
          "nativeName": {
            "type": "object",
            "description": "Official and common native country names keyed by language code.",
            "additionalProperties": {
              "$ref": "#/components/schemas/NativeName"
            },
            "example": {
              "spa": {
                "official": "República del Perú",
                "common": "Perú"
              }
            }
          }
        }
      },
      "NativeName": {
        "type": "object",
        "description": "Native country name.",
        "properties": {
          "official": {
            "type": "string",
            "example": "República del Perú"
          },
          "common": {
            "type": "string",
            "example": "Perú"
          }
        }
      },
      "Translation": {
        "type": "object",
        "description": "Translated country name.",
        "properties": {
          "official": {
            "type": "string",
            "example": "República del Perú"
          },
          "common": {
            "type": "string",
            "example": "Perú"
          }
        }
      },
      "Currency": {
        "type": "object",
        "description": "Currency information.",
        "properties": {
          "name": {
            "type": "string",
            "example": "Peruvian sol"
          },
          "symbol": {
            "type": "string",
            "example": "S/."
          }
        }
      },
      "Idd": {
        "type": "object",
        "description": "International dialing codes.",
        "properties": {
          "root": {
            "type": "string",
            "example": "+5"
          },
          "suffixes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["1"]
          }
        }
      },
      "Maps": {
        "type": "object",
        "description": "Links to maps.",
        "properties": {
          "googleMaps": {
            "type": "string",
            "format": "uri",
            "example": "https://goo.gl/maps/aGzP7m1vG1p"
          },
          "openStreetMaps": {
            "type": "string",
            "format": "uri",
            "example": "https://www.openstreetmap.org/relation/288247"
          }
        }
      },
      "Flags": {
        "type": "object",
        "description": "Links to SVG and PNG flags.",
        "properties": {
          "png": {
            "type": "string",
            "format": "uri",
            "example": "https://flagcdn.com/w320/pe.png"
          },
          "svg": {
            "type": "string",
            "format": "uri",
            "example": "https://flagcdn.com/pe.svg"
          },
          "alt": {
            "type": "string",
            "description": "Alternative text description of the flag.",
            "example": "The flag of Peru"
          }
        }
      },
      "CoatOfArms": {
        "type": "object",
        "description": "Links to SVG and PNG coat of arms images.",
        "properties": {
          "png": {
            "type": "string",
            "format": "uri",
            "example": "https://mainfacts.com/media/images/coats_of_arms/pe.png"
          },
          "svg": {
            "type": "string",
            "format": "uri",
            "example": "https://mainfacts.com/media/images/coats_of_arms/pe.svg"
          }
        }
      },
      "Car": {
        "type": "object",
        "description": "Car-related information.",
        "properties": {
          "signs": {
            "type": "array",
            "description": "Car distinguished (oval) signs.",
            "items": {
              "type": "string"
            },
            "example": ["PE"]
          },
          "side": {
            "type": "string",
            "description": "Car driving side.",
            "example": "right"
          }
        }
      },
      "Demonyms": {
        "type": "object",
        "description": "Genderized inhabitants of the country.",
        "properties": {
          "eng": {
            "$ref": "#/components/schemas/Demonym"
          },
          "fra": {
            "$ref": "#/components/schemas/Demonym"
          }
        },
        "example": {
          "eng": {
            "f": "Peruvian",
            "m": "Peruvian"
          },
          "fra": {
            "f": "Péruvienne",
            "m": "Péruvien"
          }
        }
      },
      "Demonym": {
        "type": "object",
        "description": "Demonym in a specific language.",
        "properties": {
          "f": {
            "type": "string",
            "example": "Peruvian"
          },
          "m": {
            "type": "string",
            "example": "Peruvian"
          }
        }
      },
      "Error": {
        "type": "object",
        "description": "Error response.",
        "properties": {
          "status": {
            "type": "integer",
            "example": 404
          },
          "message": {
            "type": "string",
            "example": "Not Found"
          }
        }
      }
    }
  }
}
