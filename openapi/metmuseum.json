          {
            "name": "objectID",
            "in": "path",
            "required": true,
            "description": "The unique Object ID for an object.",
            "schema": {
              "type": "integer",
              "example": 45734
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectDetail"
                },
